# Supabase Configuration (Required)
# Get these from your Supabase project settings
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# Chat Service Configuration (Required)
# URL where the Python FastAPI service is deployed
CHAT_SERVICE_URL=http://localhost:8000

# Internal API Secret (Required)
# Shared secret between Next.js and Python service for authentication
INTERNAL_API_SECRET=your_secret_key_here

# Python Service Configuration (Required)
# Groq API key for LLM inference
GROQ_API_KEY=your_groq_api_key_here

# System Prompt Path (Optional for development)
# Path to the system prompt file. Defaults to local file in development
SYSTEM_PROMPT_PATH=./system_prompt.txt
